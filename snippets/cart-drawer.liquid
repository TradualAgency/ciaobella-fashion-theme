<!-- /snippets/cart-drawer.liquid -->

{% comment %}
  * The AJAX cart drawer called by layouts/cart.drawer.liquid
  * cart {object} - the cart
  {% render 'cart-drawer', cart: cart %}
{% endcomment %}

{%- liquid
  assign hide_quantity = 'quantity--hide'
  if settings.cart_show_quantity
    assign hide_quantity = ''
  endif

  assign pop_style = 'drawer--right'
  if settings.cart_style == 'pop'
    assign pop_style = 'drawer--pop'
  endif
-%}

<nav class="drawer cart__drawer {{ pop_style }} {{ hide_quantity }} {{ settings.cart_color_bg }}"
  data-drawer="drawer-cart"
  aria-label="{{ 'layout.cart.title' | t }}"
  id="drawer-cart">
  <div class="drawer__content">
    <div class="drawer__top">

      <div class="drawer__top__left">
        <p class="cart__drawer__title">{{ 'layout.cart.title' | t }}</p>
      </div>

      <button class="drawer__button drawer__close"
        data-drawer-toggle="drawer-cart"
        aria-label="{{ 'general.accessibility.close' | t }}">
        {% render 'icon-close' %}
      </button>
    </div>
    <div class="drawer__body" data-drawer-scrolls>
      {% if settings.cart_custom_message_enable and settings.cart_custom_message_text != blank %}
        <div class="drawer__announcement__bar cart--hidden" data-cart-bar>
          {{ settings.cart_custom_message_text }}
        </div>
      {% endif %}

      {%- if settings.show_free_shipping_message and settings.free_shipping_limit != blank -%}
        {%- assign fs_limit = settings.free_shipping_limit | plus: 0 -%}
        {%- assign fs_limit_cents = fs_limit | times: 100 -%}
        {%- assign fs_subtotal = cart.total_price | plus: 0 -%}
        {%- assign fs_percent = fs_subtotal | times: 100 | divided_by: fs_limit_cents -%}
        {%- if fs_percent > 100 -%}{%- assign fs_percent = 100 -%}{%- endif -%}
        {%- assign fs_qualified = false -%}
        {%- if fs_subtotal >= fs_limit_cents -%}{%- assign fs_qualified = true -%}{%- endif -%}

        {%- capture fs_remaining -%}
          {%- if settings.currency_code_enable -%}
            {{ fs_limit_cents | minus: fs_subtotal | money_with_currency }}
          {%- else -%}
            {{ fs_limit_cents | minus: fs_subtotal | money_without_trailing_zeros }}
          {%- endif -%}
        {%- endcapture -%}

        <div class="cart-shipping-bar{% if fs_qualified %} cart-shipping-bar--qualified{% endif %}" data-shipping-bar data-limit="{{ fs_limit }}" data-cart-progress>
          <div class="cart-shipping-bar__text">
            <span class="cart-shipping-bar__success">🎉 Gefeliciteerd, je hebt gratis verzending!</span>
            <span class="cart-shipping-bar__default">Nog <strong data-shipping-remaining>{{ fs_remaining | strip }}</strong> voor gratis verzending</span>
          </div>
          <div class="cart-shipping-bar__track">
            <div class="cart-shipping-bar__fill" data-shipping-fill style="width: {{ fs_percent }}%"></div>
          </div>
        </div>

        <style>
          .cart-shipping-bar {
            padding: 12px 20px 10px;
            background: #f9f9f9;
            border-bottom: 1px solid #ebebeb;
          }
          .cart-shipping-bar__text {
            font-size: 13px;
            color: #555;
            margin-bottom: 8px;
            text-align: center;
          }
          .cart-shipping-bar__success {
            display: none;
            color: #1a7d3c;
            font-weight: 600;
          }
          .cart-shipping-bar--qualified .cart-shipping-bar__success {
            display: inline;
          }
          .cart-shipping-bar--qualified .cart-shipping-bar__default {
            display: none;
          }
          .cart-shipping-bar__track {
            height: 4px;
            background: #e0e0e0;
            border-radius: 4px;
            overflow: hidden;
          }
          .cart-shipping-bar__fill {
            height: 100%;
            background: #000;
            border-radius: 4px;
            transition: width 0.4s ease;
          }
          .cart-shipping-bar--qualified .cart-shipping-bar__fill {
            background: #1a7d3c;
          }
        </style>

        <script>
          (function() {
            function updateShippingBar(cartData) {
              var bar = document.querySelector('[data-shipping-bar]');
              if (!bar) return;
              var limit = parseFloat(bar.getAttribute('data-limit')) * 100;
              var fill = bar.querySelector('[data-shipping-fill]');
              var remainingEl = bar.querySelector('[data-shipping-remaining]');

              function applyCart(cart) {
                var subtotal = cart.total_price;
                var percent = Math.min(100, Math.round(subtotal / limit * 100));
                if (fill) fill.style.width = percent + '%';

                var qualified = subtotal >= limit;
                bar.classList.toggle('cart-shipping-bar--qualified', qualified);

                if (remainingEl) {
                  var remaining = Math.max(0, limit - subtotal);
                  remainingEl.textContent = (remaining / 100).toLocaleString('nl-NL', { style: 'currency', currency: 'EUR' });
                }
              }

              if (cartData && cartData.total_price !== undefined) {
                applyCart(cartData);
              } else {
                fetch('/cart.js').then(function(r) { return r.json(); }).then(applyCart);
              }
            }

            document.addEventListener('theme:cart:change', function(e) {
              updateShippingBar(e.detail && e.detail.cart);
            });
            document.addEventListener('theme:cart:reload', function() {
              updateShippingBar();
            });
          })();
        </script>
      {%- endif -%}

      <div class="errors" data-form-errors style="display: none;"></div>

      {% comment %}Shown if cart is empty{% endcomment %}
      <div class="cart--hidden" data-cart-empty >
        {% render 'cart-empty' %}
      </div>

      <div class="cart__items cart__items--blankstate" data-cart-blankstate>
        <div class="cart__items__row">
          <div class="item--loadbar"></div>
          <div class="cart__items__grid">
            <div class="cart__items__image">
              <span class="cart__items__img empty-content"></span>
            </div>
            <div class="cart__items__title empty-content"></div>
            <div class="cart__items__price empty-content"></div>
          </div>
        </div>
      </div>

      {% comment %}Shown if cart has contents{% endcomment %}
      <div data-cart-form data-cart-loading>
        <div data-line-items>
        </div>
      </div>
    </div>
    {%- comment -%} Vaste upsell slider op basis van collectie {%- endcomment -%}
    {%- assign upsell_collection = collections[settings.cart_upsell_collection] -%}
    {%- if upsell_collection != blank and upsell_collection.products.size > 0 -%}
      <div class="cu-slider" id="cart-upsell-slider">
        <div class="cu-slider__header">
          <span class="cu-slider__label">Misschien ook leuk</span>
          <div class="cu-slider__nav">
            <button class="cu-slider__btn" id="upsell-prev" aria-label="Vorige" disabled>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <button class="cu-slider__btn" id="upsell-next" aria-label="Volgende">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 6 15 12 9 18"/></svg>
            </button>
          </div>
        </div>
        <div class="cu-slider__viewport">
          <div class="cu-slider__track" id="upsell-track">

            {%- for upsell_p in upsell_collection.products -%}
              {%- unless upsell_p.available -%}{%- continue -%}{%- endunless -%}
              {%- assign up_variant = upsell_p.selected_or_first_available_variant -%}
              <div class="cu-slide">
                <div class="cu-card" data-cu-card>
                  <a href="{{ upsell_p.url }}" class="cu-card__img-wrap">
                    {%- if upsell_p.featured_media -%}
                      <img
                        src="{{ upsell_p.featured_media | img_url: '400x500', crop: 'center' }}"
                        alt="{{ upsell_p.featured_media.alt | default: upsell_p.title | escape }}"
                        loading="lazy"
                        width="400"
                        height="500">
                    {%- endif -%}
                  </a>
                  <div class="cu-card__body">
                    <a href="{{ upsell_p.url }}" class="cu-card__title">{{ upsell_p.title | strip_html }}</a>
                    <div class="cu-card__price">
                      <span data-cu-price>
                        {%- if settings.currency_code_enable -%}
                          {{ up_variant.price | money_with_currency }}
                        {%- else -%}
                          {{ up_variant.price | money }}
                        {%- endif -%}
                      </span>
                      {%- if up_variant.compare_at_price > up_variant.price -%}
                        <s>
                          {%- if settings.currency_code_enable -%}
                            {{ up_variant.compare_at_price | money_with_currency }}
                          {%- else -%}
                            {{ up_variant.compare_at_price | money }}
                          {%- endif -%}
                        </s>
                      {%- endif -%}
                    </div>

                    {%- unless upsell_p.has_only_default_variant -%}
                      {%- for option in upsell_p.options_with_values -%}
                        <div class="cu-card__options">
                          {%- for value in option.values -%}
                            <button
                              type="button"
                              class="cu-swatch{% if value == up_variant.options[forloop.parentloop.index0] %} is-selected{% endif %}"
                              data-cu-swatch="{{ forloop.parentloop.index0 }}"
                              data-cu-value="{{ value | escape }}"
                            >{{ value }}</button>
                          {%- endfor -%}
                        </div>
                      {%- endfor -%}
                    {%- endunless -%}

                    <form class="cu-card__form" data-cu-form>
                      <input type="hidden" name="id" value="{{ up_variant.id }}" data-cu-variant-id>
                      <input type="hidden" name="quantity" value="1">
                      <button type="submit" class="cu-card__btn" data-cu-btn {% unless up_variant.available %}disabled{% endunless %}>
                        <span class="cu-card__btn-ready">Toevoegen aan winkelwagen</span>
                        <span class="cu-card__btn-loading" aria-hidden="true">
                          <svg height="16" width="16" class="svg-loader"><circle r="6" cx="8" cy="8"/><circle stroke-dasharray="75.4 75.4" r="6" cx="8" cy="8"/></svg>
                        </span>
                      </button>
                    </form>

                    <script type="application/json" data-cu-variants>{{ upsell_p.variants | json }}</script>
                  </div>
                </div>
              </div>
            {%- endfor -%}

          </div>
        </div>
      </div>

      <style>
        .cu-slider {
          border-top: 1px solid #ebebeb;
          background: #fff;
          padding: 14px 0 0;
        }
        .cu-slider__header {
          display: flex;
          align-items: center;
          justify-content: space-between;
          padding: 0 16px 10px;
        }
        .cu-slider__label {
          font-size: 11px;
          font-weight: 600;
          text-transform: uppercase;
          letter-spacing: 0.08em;
          color: #999;
        }
        .cu-slider__nav {
          display: flex;
          gap: 6px;
        }
        .cu-slider__btn {
          display: flex;
          align-items: center;
          justify-content: center;
          width: 26px;
          height: 26px;
          border: 1px solid #ddd;
          border-radius: 50%;
          background: #fff;
          cursor: pointer;
          color: #333;
          padding: 0;
          transition: background 0.15s, border-color 0.15s, color 0.15s;
        }
        .cu-slider__btn:hover:not(:disabled) {
          background: #000;
          border-color: #000;
          color: #fff;
        }
        .cu-slider__btn:disabled {
          opacity: 0.25;
          cursor: default;
        }
        .cu-slider__viewport {
          overflow: hidden;
        }
        .cu-slider__track {
          display: flex;
          transition: transform 0.3s ease;
        }
        .cu-slide {
          min-width: 100%;
          flex-shrink: 0;
        }
        .cu-card {
          display: flex;
          gap: 14px;
          padding: 0 16px 16px;
          align-items: flex-start;
        }
        .cu-card__img-wrap {
          flex-shrink: 0;
          width: 90px;
          height: 112px;
          overflow: hidden;
          border-radius: 6px;
          background: #f5f5f5;
          display: block;
        }
        .cu-card__img-wrap img {
          width: 100%;
          height: 100%;
          object-fit: cover;
          display: block;
        }
        .cu-card__body {
          flex: 1;
          min-width: 0;
          display: flex;
          flex-direction: column;
          gap: 6px;
        }
        .cu-card__title {
          font-size: 13px;
          font-weight: 500;
          color: #000;
          text-decoration: none;
          line-height: 1.3;
          display: -webkit-box;
          -webkit-line-clamp: 2;
          -webkit-box-orient: vertical;
          overflow: hidden;
        }
        .cu-card__title:hover {
          text-decoration: underline;
        }
        .cu-card__price {
          font-size: 13px;
          font-weight: 600;
          display: flex;
          gap: 6px;
          align-items: center;
        }
        .cu-card__price s {
          font-weight: 400;
          color: #999;
          font-size: 12px;
        }
        .cu-card__options {
          display: flex;
          flex-wrap: wrap;
          gap: 4px;
        }
        .cu-swatch {
          padding: 3px 8px;
          font-size: 11px;
          border: 1px solid #ccc;
          border-radius: 3px;
          background: transparent;
          color: #333;
          cursor: pointer;
          transition: border-color 0.15s;
          line-height: 1.4;
        }
        .cu-swatch:hover {
          border-color: #666;
        }
        .cu-swatch.is-selected {
          border-color: #000;
          color: #000;
          font-weight: 600;
        }
        .cu-card__btn {
          margin-top: 2px;
          width: 100%;
          padding: 9px 12px;
          background: #000;
          color: #fff;
          border: none;
          border-radius: 4px;
          font-size: 12px;
          font-weight: 600;
          cursor: pointer;
          letter-spacing: 0.04em;
          transition: background 0.15s;
          display: flex;
          align-items: center;
          justify-content: center;
          gap: 6px;
        }
        .cu-card__btn:hover:not(:disabled) {
          background: #333;
        }
        .cu-card__btn:disabled {
          background: #ccc;
          cursor: default;
        }
        .cu-card__btn-loading {
          display: none;
        }
        .cu-card__btn.is-loading .cu-card__btn-ready {
          display: none;
        }
        .cu-card__btn.is-loading .cu-card__btn-loading {
          display: flex;
        }
        .cu-card__btn.is-done {
          background: #1a7d3c;
        }
      </style>

      <script>
        (function() {
          // Slider
          var track = document.getElementById('upsell-track');
          var prevBtn = document.getElementById('upsell-prev');
          var nextBtn = document.getElementById('upsell-next');
          if (track && prevBtn && nextBtn) {
            var slides = track.querySelectorAll('.cu-slide');
            var total = slides.length;
            var current = 0;
            function goTo(n) {
              current = Math.max(0, Math.min(n, total - 1));
              track.style.transform = 'translateX(-' + (current * 100) + '%)';
              prevBtn.disabled = current === 0;
              nextBtn.disabled = current === total - 1;
            }
            prevBtn.addEventListener('click', function() { goTo(current - 1); });
            nextBtn.addEventListener('click', function() { goTo(current + 1); });
            goTo(0);
          }

          // Swatch selection + variant switching per card
          document.querySelectorAll('[data-cu-card]').forEach(function(card) {
            var variantsEl = card.querySelector('[data-cu-variants]');
            if (!variantsEl) return;
            var variants = JSON.parse(variantsEl.textContent);
            var idInput = card.querySelector('[data-cu-variant-id]');
            var priceEl = card.querySelector('[data-cu-price]');
            var btn = card.querySelector('[data-cu-btn]');
            var selectedOptions = {};

            // Init selected options from pre-selected swatches
            card.querySelectorAll('.cu-swatch.is-selected').forEach(function(sw) {
              selectedOptions[sw.dataset.cuSwatch] = sw.dataset.cuValue;
            });

            function findVariant() {
              return variants.find(function(v) {
                return v.options.every(function(opt, idx) {
                  return !selectedOptions[idx] || selectedOptions[idx] === opt;
                });
              });
            }

            function updateVariant() {
              var variant = findVariant();
              if (!variant) return;
              idInput.value = variant.id;
              if (priceEl) {
                var price = (variant.price / 100).toLocaleString('nl-NL', { style: 'currency', currency: 'EUR' });
                priceEl.textContent = price;
              }
              if (btn) {
                btn.disabled = !variant.available;
              }
            }

            card.querySelectorAll('.cu-swatch').forEach(function(sw) {
              sw.addEventListener('click', function() {
                var groupIdx = sw.dataset.cuSwatch;
                card.querySelectorAll('[data-cu-swatch="' + groupIdx + '"]').forEach(function(s) {
                  s.classList.remove('is-selected');
                });
                sw.classList.add('is-selected');
                selectedOptions[groupIdx] = sw.dataset.cuValue;
                updateVariant();
              });
            });

            // AJAX add to cart
            var form = card.querySelector('[data-cu-form]');
            if (form) {
              form.addEventListener('submit', function(e) {
                e.preventDefault();
                btn.classList.add('is-loading');
                btn.disabled = true;
                var variantId = idInput.value;
                fetch('/cart/add.js', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                  body: JSON.stringify({ id: parseInt(variantId), quantity: 1 })
                })
                .then(function(r) { return r.json(); })
                .then(function() {
                  btn.classList.remove('is-loading');
                  btn.classList.add('is-done');
                  btn.querySelector('.cu-card__btn-ready').textContent = 'Toegevoegd ✓';
                  setTimeout(function() {
                    btn.classList.remove('is-done');
                    btn.querySelector('.cu-card__btn-ready').textContent = 'Toevoegen aan winkelwagen';
                    btn.disabled = false;
                  }, 2000);
                  // Trigger theme cart reload (updates line items, count, totals, shipping bar)
                  document.dispatchEvent(new CustomEvent('theme:cart:reload'));
                })
                .catch(function() {
                  btn.classList.remove('is-loading');
                  btn.disabled = false;
                });
              });
            }
          });
        })();
      </script>
    {%- endif -%}

    <div class="drawer__bottom cart--hidden" data-cart-bottom data-accordion-group>
      {%- if settings.cart_notes_enable or settings.cart_shipping_enable -%}
        <div class="drawer__accordion__holder">
          {%- if settings.cart_notes_enable -%}
            <div class="drawer__bottom__notes drawer__accordion">
              <button class="accordion__title"
                data-accordion-trigger="accordion-cart-notes"
                aria-controls="accordion-{{ key }}"
                aria-haspopup="true"
                aria-expanded="false">
                {{ 'cart.general.note' | t }}
              </button>
              <div class="accordion__body drawer__accordion__body"
                data-accordion-body
                id="accordion-cart-notes">
                <label class="visually-hidden" for="CartSpecialInstructions">{{ 'cart.general.note' | t }}</label>
                <textarea name="note" placeholder="{{ 'cart.general.note' | t }}" class="drawer__notes__input input-full" id="CartSpecialInstructions" data-cart-note>{{ cart.note }}</textarea>
              </div>
            </div>
          {%- endif -%}

          {%- if settings.cart_shipping_enable -%}
            {% render 'cart-shipping' %}
          {%- endif -%}
        </div>
      {%- endif -%}

      <p class="drawer__bottom__meta small"><em>{{ 'cart.general.shipping_at_checkout' | t }}</em></p>

      <div class="drawer__footer__subtotal" data-cart-subtotal>
        {% render 'cart-subtotal' %}
      </div>

      <form action="{{ routes.cart_url }}" method="post" novalidate class="cart">
        <button type="submit" name="checkout" class="btn btn--primary btn--large btn--full checkout__button" role="button">
          {{ 'cart.general.checkout' | t }} <em>•</em>
          <span data-cart-final>
            {{ cart.total_price | money_with_currency }}
          </span>
        </button>
      </form>
      {% if additional_checkout_buttons and settings.cart_show_additional_buttons %}
        <div class="drawer__checkout__additional additional-checkout-buttons--vertical">
          <div class="additional-checkout-buttons">
            {{ content_for_additional_checkout_buttons }}
          </div>
        </div>
      {% endif %}
    </div>
  </div>
  <span class="drawer__underlay" data-drawer-underlay>
    <span class="drawer__underlay__fill"></span>
    <span class="drawer__underlay__blur"></span>
  </span>
</nav>
