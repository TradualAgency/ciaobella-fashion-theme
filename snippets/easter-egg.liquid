<!-- Easter Egg Hunt - Pasen 2026 -->
<style>
  .easter-egg {
    position: fixed;
    z-index: 9998;
    cursor: pointer;
    font-size: 36px;
    line-height: 1;
    transition: transform 0.2s ease;
    animation: easter-egg-bounce 3s ease-in-out infinite;
    user-select: none;
  }
  .easter-egg:hover {
    transform: scale(1.3);
  }

  @keyframes easter-egg-bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  .easter-popup-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.5);
    align-items: center;
    justify-content: center;
  }
  .easter-popup-overlay.is-visible {
    display: flex;
  }

  .easter-popup {
    background: #fff;
    border-radius: 16px;
    padding: 40px;
    max-width: 400px;
    width: 90%;
    text-align: center;
    position: relative;
    animation: easter-popup-in 0.3s ease;
  }

  @keyframes easter-popup-in {
    from { opacity: 0; transform: scale(0.9) translateY(10px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  .easter-popup__emoji {
    font-size: 48px;
    margin-bottom: 12px;
  }
  .easter-popup__title {
    font-size: 1.4em;
    font-weight: bold;
    margin-bottom: 8px;
  }
  .easter-popup__text {
    margin-bottom: 20px;
    color: #555;
    line-height: 1.5;
  }
  .easter-popup__code {
    display: inline-block;
    background: #f5f5f5;
    border: 2px dashed #000;
    border-radius: 8px;
    padding: 12px 24px;
    font-size: 1.3em;
    font-weight: bold;
    letter-spacing: 2px;
    margin-bottom: 16px;
    cursor: pointer;
    transition: background 0.2s;
  }
  .easter-popup__code:hover {
    background: #e8e8e8;
  }
  .easter-popup__copy-msg {
    font-size: 0.85em;
    color: #888;
    margin-bottom: 16px;
  }
  .easter-popup__close {
    position: absolute;
    top: 12px;
    right: 16px;
    background: none;
    border: none;
    font-size: 24px;
    cursor: pointer;
    color: #999;
    line-height: 1;
  }
  .easter-popup__close:hover {
    color: #000;
  }
</style>

<div class="easter-egg" id="easter-egg" aria-label="Paaseitje gevonden!" role="button" tabindex="0">
  <svg width="40" height="50" viewBox="0 0 40 50">
    <ellipse cx="20" cy="28" rx="17" ry="22" fill="#F48FB1"/>
    <circle cx="12" cy="20" r="3" fill="#fff" opacity="0.8"/>
    <circle cx="26" cy="16" r="2.5" fill="#fff" opacity="0.8"/>
    <circle cx="18" cy="34" r="2.5" fill="#fff" opacity="0.8"/>
    <circle cx="28" cy="30" r="2" fill="#fff" opacity="0.8"/>
    <circle cx="10" cy="32" r="2" fill="#fff" opacity="0.8"/>
    <circle cx="22" cy="22" r="1.8" fill="#fff" opacity="0.6"/>
    <circle cx="14" cy="40" r="2" fill="#fff" opacity="0.7"/>
    <circle cx="26" cy="40" r="1.5" fill="#fff" opacity="0.6"/>
    <ellipse cx="20" cy="28" rx="17" ry="22" fill="none" stroke="#E91E63" stroke-width="0.8" opacity="0.3"/>
  </svg>
</div>

<div class="easter-popup-overlay" id="easter-popup">
  <div class="easter-popup">
    <button class="easter-popup__close" id="easter-popup-close" aria-label="Sluiten">&times;</button>
    <div class="easter-popup__emoji">🐣🎉</div>
    <div class="easter-popup__title">Je hebt een paaseitje gevonden!</div>
    <p class="easter-popup__text">Vrolijk Pasen! Gebruik onderstaande kortingscode bij je bestelling.</p>
    <div class="easter-popup__code" id="easter-code">EASTER2026</div>
    <div class="easter-popup__copy-msg" id="easter-copy-msg">Klik op de code om te kopieren</div>
  </div>
</div>

<script>
  (function() {
    var COOKIE_NAME = 'easter_egg_found';

    function getCookie(name) {
      var match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
      return match ? match[2] : null;
    }

    function setCookie(name, value, days) {
      var d = new Date();
      d.setTime(d.getTime() + (days * 24 * 60 * 60 * 1000));
      document.cookie = name + '=' + value + ';expires=' + d.toUTCString() + ';path=/';
    }

    if (getCookie(COOKIE_NAME)) return;

    var egg = document.getElementById('easter-egg');
    var popup = document.getElementById('easter-popup');
    var closeBtn = document.getElementById('easter-popup-close');
    var codeEl = document.getElementById('easter-code');
    var copyMsg = document.getElementById('easter-copy-msg');

    // Random position within viewport
    var maxX = window.innerWidth - 50;
    var maxY = window.innerHeight - 50;
    var posX = Math.floor(Math.random() * (maxX - 60)) + 30;
    var posY = Math.floor(Math.random() * (maxY - 100)) + 80;

    egg.style.left = posX + 'px';
    egg.style.top = posY + 'px';
    egg.style.display = 'block';

    egg.addEventListener('click', function() {
      egg.style.display = 'none';
      popup.classList.add('is-visible');
      setCookie(COOKIE_NAME, '1', 7);
    });

    closeBtn.addEventListener('click', function() {
      popup.classList.remove('is-visible');
    });

    popup.addEventListener('click', function(e) {
      if (e.target === popup) {
        popup.classList.remove('is-visible');
      }
    });

    codeEl.addEventListener('click', function() {
      if (navigator.clipboard) {
        navigator.clipboard.writeText('EASTER2026').then(function() {
          copyMsg.textContent = 'Gekopieerd!';
          setTimeout(function() { copyMsg.textContent = 'Klik op de code om te kopieren'; }, 2000);
        });
      }
    });
  })();
</script>
